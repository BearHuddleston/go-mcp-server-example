{
  "schemaVersion": "v1",
  "server": {
    "name": "Incident Runbook MCP",
    "version": "1.0.0"
  },
  "runtime": {
    "transportType": "http",
    "httpPort": 8080,
    "requestTimeout": "60s",
    "allowedOrigins": [
      "http://localhost:*",
      "http://127.0.0.1:*"
    ]
  },
  "items": [
    {
      "incident_name": "API Latency Spike",
      "severity_profile": "sev2",
      "service_scope": "api-gateway",
      "summary": "Runbook for diagnosing latency regressions across service dependencies."
    },
    {
      "incident_name": "Database Connection Saturation",
      "severity_profile": "sev1",
      "service_scope": "primary-database",
      "summary": "Runbook for pool exhaustion, lock contention, and failover choices."
    },
    {
      "incident_name": "Queue Backlog Growth",
      "severity_profile": "sev2",
      "service_scope": "event-consumers",
      "summary": "Runbook for consumer lag, dead-letter spikes, and throughput recovery."
    }
  ],
  "tools": [
    {
      "mode": "list_items",
      "name": "listRunbooks",
      "description": "List available incident runbooks",
      "inputSchema": {
        "type": "object",
        "properties": {},
        "required": []
      }
    },
    {
      "mode": "get_item_details",
      "name": "getRunbook",
      "description": "Get runbook details by incident name",
      "inputSchema": {
        "type": "object",
        "properties": {
          "incident_name": {
            "type": "string"
          }
        },
        "required": [
          "incident_name"
        ]
      }
    }
  ],
  "resources": [
    {
      "mode": "catalog_items",
      "uri": "catalog://runbooks",
      "name": "incident-runbooks"
    }
  ],
  "prompts": [
    {
      "mode": "plan_recommendation",
      "name": "recommendIncidentPlan",
      "description": "Recommend a response plan for incident pressure",
      "arguments": [
        {
          "name": "budget",
          "description": "Response effort budget",
          "required": false
        },
        {
          "name": "goal",
          "description": "Primary incident objective",
          "required": false
        }
      ],
      "template": "Recommend an incident response plan%s%s with immediate, short-term, and long-term actions."
    },
    {
      "mode": "item_brief",
      "name": "runbookBrief",
      "description": "Create a concise runbook brief",
      "arguments": [
        {
          "name": "incident_name",
          "description": "Runbook to summarize",
          "required": true
        }
      ],
      "template": "Write a concise incident brief for %s with triage steps and escalation criteria."
    }
  ]
}
